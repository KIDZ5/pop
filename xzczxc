// Crypto Core
async function getPasswordKey(password, salt) { 
    const enc = new TextEncoder();
    const keyMaterial = await crypto.subtle.importKey("raw", enc.encode(password), { name: "PBKDF2" }, false, ["deriveKey"]);
    return crypto.subtle.deriveKey({ name: "PBKDF2", salt: salt, iterations: 100000, hash: "SHA-256" }, keyMaterial, { name: "AES-GCM", length: 256 }, false, ["encrypt", "decrypt"]);
}
async function encryptText(text, password) { 
    const enc = new TextEncoder(); const data = enc.encode(text); const salt = crypto.getRandomValues(new Uint8Array(16));
    const iv = crypto.getRandomValues(new Uint8Array(12)); const key = await getPasswordKey(password, salt);
    const encryptedBuffer = await crypto.subtle.encrypt({ name: "AES-GCM", iv: iv }, key, data); const encryptedArray = new Uint8Array(encryptedBuffer);
    const combined = new Uint8Array(salt.length + iv.length + encryptedArray.length); combined.set(salt, 0); combined.set(iv, salt.length); combined.set(encryptedArray, salt.length + iv.length);
    return btoa(Array.from(combined, byte => String.fromCharCode(byte)).join("")); 
}

// ==========================================
