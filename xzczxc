        Swal.fire({ title: 'สแกนล้มเหลว', text: 'ไม่สามารถเจาะระบบเว็บนี้ได้ (ติดระบบป้องกัน)', icon: 'error' });
        return;
    }

    const doc = new DOMParser().parseFromString(html, "text/html");
    const links = doc.querySelectorAll('a');
    let foundChapters = new Map();

    // กวาดทุกลิงก์ในหน้าเว็บ เพื่อหาตอน
    links.forEach(a => {
        let info = extractChapterInfo(a, indexUrl);
        // ถ้าเจอเลขตอน และยังไม่เคยบันทึก หรือลิงก์ใหม่ยาวกว่า (มักจะเป็นลิงก์จริง) ให้บันทึก
        if (info && !isNaN(info.num)) {
            if (!foundChapters.has(info.num) || foundChapters.get(info.num).length < info.url.length) {
                foundChapters.set(info.num, info.url);
            }
        }
    });

    if (foundChapters.size === 0) {
        Swal.fire({ title: 'ไม่พบลิงก์', text: 'สแกนไม่พบลิงก์ตอนมังงะในหน้านี้เลย', icon: 'error' });
        return;
    }

    // จัดเรียงเลขตอนจากน้อยไปมาก
    const sortedNums = Array.from(foundChapters.keys()).sort((a, b) => a - b);
    
    // สร้างกล่อง UI ตามจำนวนตอนที่พบจริงๆ (แทนที่ generateChapterInputs เดิม)
