let libData = [];
let libFilteredData = [];
let currentPage = 1; const itemsPerPage = 6; let selectedIds = new Set();

function initLibrary(series, chapters) { 
    const mappedSeries = series.map(s => ({ ...s, _type: 'series', _status: s.status || 'Ongoing' }));
    const mappedChapters = chapters.map(c => ({ ...c, _type: 'chapter', _status: 'Release' })); 
    libData = [...mappedSeries, ...mappedChapters].sort((a,b) => b.updated?.localeCompare(a.updated) || 0);
    handleLibraryFilter(); 
}

function handleLibraryFilter() { 
    const query = document.getElementById("lib-search").value.toLowerCase(); const typeFilter = document.getElementById("lib-type-filter").value;
    libFilteredData = libData.filter(item => { const matchSearch = item.title.toLowerCase().includes(query) || (item.commonTag && item.commonTag.toLowerCase().includes(query)); return matchSearch && (typeFilter === 'all' || item._type === typeFilter); });
    currentPage = 1; selectedIds.clear(); updateBatchToolbarUI(); renderTablePage(); 
}

function getStatusBadge(status) { 
    status = status.toLowerCase();
    if(status === 'ongoing') return `<span class="text-[10px] font-bold px-2 py-0.5 rounded border bg-teal-50 text-teal-600 border-teal-200 dark:bg-teal-500/10 dark:text-teal-400 dark:border-teal-500/20 uppercase tracking-wider">กำลังแปล</span>`;
    if(status === 'completed') return `<span class="text-[10px] font-bold px-2 py-0.5 rounded border bg-blue-50 text-blue-600 border-blue-200 dark:bg-blue-500/10 dark:text-blue-400 dark:border-blue-500/20 uppercase tracking-wider">จบแล้ว</span>`;
    return `<span class="text-[10px] font-bold px-2 py-0.5 rounded border bg-gray-100 text-gray-600 border-gray-300 dark:bg-gray-800 dark:text-gray-400 dark:border-gray-700 uppercase tracking-wider">เผยแพร่</span>`;
}

