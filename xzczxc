}

async function lockChapter(index) {
    const password = document.getElementById('vault-password').value;
    const textarea = document.getElementById(`cap-val-${index}`); const rawHtml = textarea.value;
    if (!password) { Swal.fire({title: 'เกิดข้อผิดพลาด', text: 'กรุณาตั้งรหัสผ่าน Vault ด้านบนก่อน!', icon: 'error'}); return; } 
    if (!rawHtml.trim()) { Swal.fire({title: 'คำเตือน', text: 'คุณยังไม่ได้ใส่เนื้อหาในตอนนี้!', icon: 'warning'}); return; } 
    if (textarea.classList.contains('locked-area')) { Swal.fire({title: 'รับทราบ', text: 'ตอนนี้ถูกเข้ารหัสและล็อกไว้แล้ว!', icon: 'info'}); return; }
    
    const parser = new DOMParser(); const doc = parser.parseFromString(rawHtml, 'text/html');
    const urls = []; doc.querySelectorAll('img').forEach(img => { const url = img.getAttribute('data-src') || img.getAttribute('src'); if (url && !url.includes('loading.png')) urls.push(url); });
    if (urls.length === 0) { Swal.fire({title: 'เกิดข้อผิดพลาด', text: 'ไม่พบลิงก์รูปภาพให้เข้ารหัส!', icon: 'error'}); return; }
    
    try { 
        const encrypted = await encryptText(JSON.stringify(urls), password);
        textarea.value = encrypted; textarea.classList.add('locked-area'); textarea.readOnly = true;
        const iconDiv = document.getElementById(`lock-icon-${index}`); iconDiv.setAttribute('data-lucide', 'lock'); iconDiv.classList.replace('text-gray-400', 'text-indigo-500'); lucide.createIcons();
    } catch (e) { Swal.fire({title: 'เกิดข้อผิดพลาด', text: 'การเข้ารหัสล้มเหลว!', icon: 'error'}); console.error(e); }
}

async function lockAllChapters() { 
