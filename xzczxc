<script id="script-main">
/*<![CDATA[*/
lucide.createIcons();
const DEFAULT_IMG = "https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEgcpJA-XCwTra_3S53QFkfxXEKsI1FOZtpBB-vUksTY1qod7mc9V-XizRUu_dJA6KolOwCSUhpQgJCCouTzs-sap-7MhnNGrwZA041TxWTq2RAVFIrweNNeHFjIRUwKF-OpZGijYnajmNVG0zz3ZaOfTWD2XJ4pBv81txeBfTzFpmivnnHzXjlxyvLvf-9u/h324-w200-c/0.webp";

// Helper: ถอดรหัส HTML Entities ที่ Blogger แปลงอัตโนมัติ (Anti-Encoding)
const tDec = (str) => { 
    if(!str) return "";
    const txt = document.createElement("textarea"); 
    txt.innerHTML = str; 
    return txt.value; 
};

// --- 1. ENHANCED SYSTEM LOGGING & UTILS ---
function scrollToEl(id) { const el = document.getElementById(id); if(el) el.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
function toggleTheme() { const html = document.documentElement; if(html.classList.contains('dark')) { html.classList.remove('dark'); localStorage.setItem('theme', 'light'); } else { html.classList.add('dark'); localStorage.setItem('theme', 'dark'); } }
if(localStorage.getItem('theme') === 'light') document.documentElement.classList.remove('dark');

(function () {
    const term = document.getElementById("terminal-output"); 
    const oldLog = console.log; const oldWarn = console.warn; const oldError = console.error;
    function appendLog(type, action, msg) {
        if (!term) return; 
        const t = new Date().toLocaleTimeString('th-TH', { hour12: false }); 
        let color = 'text-teal-400'; if(type === 'warn') color = 'text-amber-400'; if(type === 'error') color = 'text-red-400';
        term.innerHTML += `<div class="py-1 border-b border-gray-800/50 flex gap-2"><span class="text-gray-500 font-mono">[${t}]</span> <span class="font-bold ${color} uppercase tracking-wider">[${action}]</span> <span class="text-gray-300">${msg}</span></div>`; 
        term.scrollTop = term.scrollHeight;
    }
    console.log = function (...a) { 
        oldLog.apply(console, a); let text = a.join(" "); let action = "ระบบ";
        if(text.includes("[DB")) action = "ฐานข้อมูล"; else if(text.includes("[Editor]")) action = "ตัวแก้ไข-GUI";
        else if(text.includes("[Sync]")) { action = "ซิงค์เอ็นจิ้น"; if(text.includes("Finished") || text.includes("Success")) { const icon = document.getElementById("sync-icon"); if(icon) icon.classList.remove("animate-spin"); initializeDashboard(); } }
        appendLog('log', action, text.replace(/\[.*?\]/g, '').trim()); 
    };
    console.warn = function (...a) { oldWarn.apply(console, a); let text = a.join(" "); appendLog('warn', text.includes("[Sync]") ? 'การแจ้งเตือนซิงค์' : 'คำเตือน', text.replace(/\[.*?\]/g, '').trim()); };
    console.error = function (...a) { oldError.apply(console, a); appendLog('error', 'ระบบล้มเหลว', a.join(" ").replace(/\[.*?\]/g, '').trim()); };
})();

// --- 2. DB INITIALIZATION & DASHBOARD BOOT ---
async function initializeDashboard() {
    console.log("[SYSTEM] กำลังบูตระบบแผงควบคุม...");
    const pStart = performance.now();
    try {
        const db = await initDB();
        document.getElementById("nav-db-info").innerHTML = `<i data-lucide="hard-drive" class="w-3 h-3"></i> ${db.name} <span class="opacity-50 ml-1">v${db.version}</span>`; lucide.createIcons();
        const series = await new Promise(r => db.transaction("series").objectStore("series").getAll().onsuccess = e => r(e.target.result));
        const chapters = await new Promise(r => db.transaction("chapters").objectStore("chapters").getAll().onsuccess = e => r(e.target.result));
        
        // Use .innerHTML instead of .innerText to bypass Blogger Encoding
        document.getElementById("dash-total-series").innerHTML = series.length;
        document.getElementById("dash-total-chapters").innerHTML = chapters.length;
        document.getElementById("dash-locked-items").innerHTML = series.filter(s=>s.isLocked).length + chapters.filter(c=>c.isLocked).length;

        let initialSeries = parseInt(localStorage.getItem('init_series_count')); let initialChapters = parseInt(localStorage.getItem('init_chapters_count'));
        if(isNaN(initialSeries)) { localStorage.setItem('init_series_count', series.length); initialSeries = series.length; }
        if(isNaN(initialChapters)) { localStorage.setItem('init_chapters_count', chapters.length); initialChapters = chapters.length; }
        document.getElementById('stat-growth-series').innerHTML = (series.length - initialSeries >= 0 ? '+' : '') + (series.length - initialSeries) + ' เรื่อง';
        document.getElementById('stat-growth-chapters').innerHTML = (chapters.length - initialChapters >= 0 ? '+' : '') + (chapters.length - initialChapters) + ' ตอน';

        const breakdown = { Manga: 0, Manhwa: 0, Manhua: 0, Doujin: 0, Novel: 0 }; let totalCategorized = 0;
        series.forEach(s => { let isCounted = false; if(s.label) { const labels = s.label.map(l => l.toLowerCase()); if(labels.includes('manga')) { breakdown.Manga++; isCounted = true; } else if(labels.includes('manhwa')) { breakdown.Manhwa++; isCounted = true; } else if(labels.includes('manhua')) { breakdown.Manhua++; isCounted = true; } else if(labels.includes('doujin')) { breakdown.Doujin++; isCounted = true; } else if(labels.includes('novel')) { breakdown.Novel++; isCounted = true; } } if(isCounted) totalCategorized++; });
        ['Manga', 'Manhwa', 'Manhua', 'Doujin', 'Novel'].forEach(cat => { const count = breakdown[cat]; const pct = totalCategorized > 0 ? Math.round((count / totalCategorized) * 100) : 0; const elCount = document.getElementById(`breakdown-${cat.toLowerCase()}-count`); const elBar = document.getElementById(`breakdown-${cat.toLowerCase()}-bar`); if(elCount) elCount.innerHTML = `${count} <span class="text-[9px] text-gray-400">(${pct}%)</span>`; if(elBar) elBar.style.width = `${pct}%`; });

        document.getElementById("stat-active").innerHTML = series.length + chapters.length;
        if (navigator.storage && navigator.storage.estimate) { const est = await navigator.storage.estimate();
            let size = "0KB", pct = 5; if(est.usage) { size = est.usage > 1048576 ? (est.usage / 1048576).toFixed(2) + "MB" : (est.usage / 1024).toFixed(1) + "KB"; pct = Math.max(5, (est.usage / est.quota) * 100); } 
            document.getElementById("stat-storage").innerHTML = size;
            document.getElementById("storage-bar").style.width = pct + "%"; 
        }
        let lsTotalBytes = 0;
        for(let x in localStorage) { if(localStorage.hasOwnProperty(x)) { lsTotalBytes += ((localStorage[x].length + x.length) * 2); } } 
        const lsLimitBytes = 5 * 1024 * 1024;
        const lsPct = Math.min(100, Math.max(5, (lsTotalBytes / lsLimitBytes) * 100));
        document.getElementById('stat-ls-storage').innerHTML = lsTotalBytes > 1048576 ? (lsTotalBytes / 1048576).toFixed(2) + 'MB' : (lsTotalBytes / 1024).toFixed(1) + 'KB';
        document.getElementById('ls-storage-bar').style.width = lsPct + '%';

        initLibrary(series, chapters); initHealth(series, chapters);
        if(typeof populateStudioSeriesDropdown === "function") populateStudioSeriesDropdown(series);
        document.getElementById("stat-latency").innerHTML = `${Math.round(performance.now() - pStart)}ms`;
    } catch(e) { console.error("[DB:ERROR] โหลดฐานข้อมูลล้มเหลว:", e.message); }
}

