function updateHistoryRange() { 
    if (!selectedManga) return; 
    saveToHistory(selectedManga.id, selectedManga.title, selectedManga.cover, document.getElementById('m-start').value, document.getElementById('m-end').value);
}

// ฟังก์ชันหัวใจหลัก: สร้าง Array ของเลขตอนทั้งหมด (รวมตอนหลักและตอนย่อย) เรียงจากน้อยไปมาก
function getChapterArray() {
    const start = parseInt(document.getElementById('m-start').value) || 1;
    const end = parseInt(document.getElementById('m-end').value) || 0;
    const subsStr = document.getElementById('m-subs') ? document.getElementById('m-subs').value : "";
    
    let arr = [];
    // 1. สร้างลำดับตอนปกติ (จำนวนเต็ม)
    if (start <= end && start > 0) {
        for (let i = start; i <= end; i++) arr.push(i);
    }
    
    // 2. แทรกตอนย่อยจากช่อง Input
    if (subsStr) {
        const subs = subsStr.split(',').map(s => parseFloat(s.trim())).filter(n => !isNaN(n));
        arr.push(...subs);
    }
    
    // 3. ลบตัวซ้ำและจัดเรียงลำดับจากน้อยไปมากให้สวยงาม
    return [...new Set(arr)].sort((a, b) => a - b);
}

function generateChapterInputs() {
