async function exportDatabase() { 
    console.log("[DB:EXPORT] กำลังสร้างไฟล์สำรอง XML..."); 
    const db = await initDB();
    const series = await new Promise(r => db.transaction("series").objectStore("series").getAll().onsuccess = e => r(e.target.result));
    const chapters = await new Promise(r => db.transaction("chapters").objectStore("chapters").getAll().onsuccess = e => r(e.target.result));
    let xml = `<?xml version='1.0' encoding='UTF-8'?><feed xmlns='http://www.w3.org/2005/Atom'><title type='text'>MangaDB Backup</title><generator>MangaDB System</generator>`;
    const escapeXML = (str) => (str || "").replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&apos;'); 
    [...series, ...chapters].forEach(item => { 
        let isSeries = item._type === 'series'; 
        let categories = item.label ? item.label.map(l => `<category scheme="http://www.blogger.com/atom/ns#" term="${escapeXML(l)}"/>`).join('') : ''; 
        let tags = `<category scheme="http://www.blogger.com/atom/ns#" term="${isSeries ? 'Series' : 'Chapter'}"/>` + categories; 
        let content = item.offlineContent ? item.offlineContent : `<img src="${item.image}"/><br/>MangaDB System Backup Record: ${item.title}`; 
        xml += `<entry><category scheme="http://schemas.google.com/g/2005#kind" term="http://schemas.google.com/blogger/2008/kind#post"/>${tags}<title type='text'>${escapeXML(item.title)}</title><content type='html'>${escapeXML(content)}</content><published>${item.updated || new Date().toISOString()}</published></entry>`; 
    }); 
    xml += `</feed>`;
    
    // เติม BOM เพื่อแก้ปัญหาภาษาไทยให้ Blogger Importer อ่านออก
    const blob = new Blob(["\ufeff", xml], { type: 'application/xml;charset=utf-8' });
    const url = URL.createObjectURL(blob); const a = document.createElement('a'); a.href = url;
    a.download = `MangaDB_Backup_${Date.now()}.xml`; document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url);
}

