<script>
(function() {
  // 1. สร้างฟังก์ชันช่วยแปลงรหัส HTML Entities ให้กลับเป็นข้อความปกติ (ภาษาไทย/Emoji)
  function decodeText(encodedText) {
    var textArea = document.createElement("textarea");
    textArea.innerHTML = encodedText;
    return textArea.value;
  }

  const ADMIN_KEY = 'chathai_admin_2025';
  const STORED = localStorage.getItem('admin_session');
  
  // 2. ถ้ายังไม่ได้ unlock
  if (STORED !== ADMIN_KEY) {
    // ใช้ฟังก์ชัน decodeText() ครอบข้อความของเราเอาไว้
    const promptMessage = decodeText('🔐 Admin Access Required\nกรอกรหัสผ่าน:');
    const pass = prompt(promptMessage);
    
    if (pass === 'ChathaiManga2005') {
      localStorage.setItem('admin_session', ADMIN_KEY);
    } else {
      // ใช้ฟังก์ชัน decodeText() สำหรับแจ้งเตือนเช่นกัน
      const alertMessage = decodeText('❌ ไม่มีสิทธิ์เข้าถึง');
      alert(alertMessage);
      window.location.href = '/';
    }
  }
})();
</script>


