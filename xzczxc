    }
    return null;
}

// สุดยอดเอนจินสกัดภาพ (Heuristic & Sequential Extractor)
function extractImages(html, chapterTitle) {
    let rawUrls = [];
    
    // 1. ขุดเจาะจาก JavaScript Arrays (ทะลวงระบบที่ซ่อนรูปลับๆ)
    const scriptBlocks = html.match(/<script[^>]*>([\s\S]*?)<\/script>/gi) || [];
    for (let script of scriptBlocks) {
        let match = script.match(/ts_reader\.run\((.*?)\);/);
        if (match) { try { let data = JSON.parse(match[1]); if(data.sources && data.sources[0]) rawUrls.push(...data.sources[0].images); } catch(e){} }
        
        match = script.match(/chapter_preloaded_images\s*=\s*\[(.*?)\]/);
        if (match) { let links = match[1].match(/(https?:\/\/[^"'\s\\]+)/g); if (links) rawUrls.push(...links.map(l => l.replace(/\\/g, ''))); }
        
        match = script.match(/["']images["']\s*:\s*\[(.*?)\]/);
        if (match) { let links = match[1].match(/(https?:\/\/[^"'\s\\]+)/g); if (links) rawUrls.push(...links.map(l => l.replace(/\\/g, ''))); }
    }

    // 2. ขุดเจาะจาก HTML DOM ทั่วไป
    if (rawUrls.length === 0) {
        const doc = new DOMParser().parseFromString(html, "text/html");
        let allImages = doc.querySelectorAll('img');
        allImages.forEach(img => {
            // ดักทุก attribute ที่เป็นไปได้ในโลก (ป้องกันอนาคต)
            let src = img.getAttribute('data-src') || img.getAttribute('data-lazy-src') || img.getAttribute('data-original') || 
                      img.getAttribute('data-cfsrc') || img.getAttribute('data-aload') || img.getAttribute('src');
            if (src) rawUrls.push(src.trim());
        });
    }

    // ทำความสะอาดเบื้องต้น
    let validUrls = [...new Set(rawUrls)].filter(url => url.startsWith('http') && !url.match(/(gif|lazyload|spinner|loader|1x1|blank)/i));

    // 3. ระบบให้คะแนนอัจฉริยะ (Sequential Scoring System) - อาวุธลับตัดโฆษณา
    let pathGroups = {};
    validUrls.forEach(url => {
        try {
            let parsed = new URL(url);
            let dirPath = parsed.hostname + parsed.pathname.substring(0, parsed.pathname.lastIndexOf('/') + 1);
            if (!pathGroups[dirPath]) pathGroups[dirPath] = [];
            pathGroups[dirPath].push(url);
        } catch(e){}
    });

    let bestGroup = [];
    let maxScore = -9999;

    for (let dir in pathGroups) {
        let urls = pathGroups[dir];
        let score = urls.length; // คะแนนพื้นฐานคือจำนวนรูป

        // โบนัส: ถ้ารูปในโฟลเดอร์นี้มีตัวเลขในชื่อไฟล์ (เช่น 01.jpg) ให้คะแนนพิเศษเยอะมาก!
        let hasNumbers = urls.filter(u => /\d{1,4}\.(jpg|png|webp|jpeg)/i.test(u.split('/').pop())).length;
        score += (hasNumbers * 5); 

        // บทลงโทษ: ถ้าชื่อโฟลเดอร์มีคำพวกนี้ ติดลบทันที (โฆษณา/โลโก้/UI)
        if (dir.match(/(banner|ads|avatar|logo|icon|bg|background|widget|sponsor|upload\/author)/i)) {
            score -= 500;
        }

        if (score > maxScore) {
            maxScore = score;
            bestGroup = urls;
        }
    }

    // ถ้ากลุ่มที่ชนะมีรูปพอสมควร ถือว่าเป็นมังงะ
    if (bestGroup.length >= 2) validUrls = bestGroup;

    return [...new Set(validUrls)].map((src, i) => `<img src="${src}" loading="lazy" alt="${chapterTitle} - หน้า ${i+1}" />`);
}

