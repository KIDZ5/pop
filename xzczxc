}

// XML Builder
function cleanHTML(rawHTML, chapterTitle) {
    if (!rawHTML.trim()) return ""; if (!rawHTML.includes('<img')) return rawHTML;
    const parser = new DOMParser(); const doc = parser.parseFromString(rawHTML, 'text/html'); const imgs = doc.querySelectorAll('img'); const targetRes = document.getElementById('img-res').value;
    let output = "";
    imgs.forEach((img, idx) => { let src = img.getAttribute('src') || ""; if (targetRes !== 'original') src = src.replace(/\/(s|w|h)\d+\//g, `/${targetRes}/`); const dataW = img.getAttribute('data-original-width'); const dataH = img.getAttribute('data-original-height'); let tag = `<img alt="${chapterTitle} - หน้า ${idx + 1}" src="${src}" loading="lazy"`; if (dataW && dataH) tag += ` width="${dataW}" height="${dataH}"`; tag += `/>`; output += tag + "\n"; });
    return output.trim();
}

function buildVerifiedBloggerXML(dataArray, filename, part) {
    const isDraft = document.getElementById('post-status').value === 'draft';
    const entriesXml = dataArray.map((item, index) => { const dateObj = new Date(Date.now() - (index * 60000)); const uniqueId = Date.now() + index + (part * 777); const entryId = `tag:blogger.com,1999:blog-${BLOG_ID}.post-${uniqueId}`; const esc = (s) => s.toString().replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":"&#39;"})[m]); const cats = item.labels.map(l => `<category scheme="http://www.blogger.com/atom/ns#" term="${esc(l)}" />`).join('\n'); const draftXml = isDraft ? `<app:control xmlns:app='http://www.w3.org/2007/app'><app:draft>yes</app:draft></app:control>` : ''; return `<entry><id>${entryId}</id><published>${dateObj.toISOString()}</published><updated>${dateObj.toISOString()}</updated>${draftXml}<category scheme="http://schemas.google.com/g/2005#kind" term="http://schemas.google.com/blogger/2008/kind#post" /><title type="text">${esc(item.title)}</title><content type="html">${esc(item.content)}</content><author><name>Admin</name></author></entry>`; }).join('\n');
