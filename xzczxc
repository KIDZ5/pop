// --- BATCH LOGIC ---
function toggleSelectRow(id) { if(selectedIds.has(id)) selectedIds.delete(id); else selectedIds.add(id); updateBatchToolbarUI(); renderTablePage(); }
function toggleSelectAllVisible(checkbox) { 
    const startIdx = (currentPage - 1) * itemsPerPage;
    const endIdx = Math.min(startIdx + itemsPerPage, libFilteredData.length);
    const paginatedItems = libFilteredData.slice(startIdx, endIdx); 
    if(checkbox.checked) paginatedItems.forEach(item => selectedIds.add(item.id)); 
    else paginatedItems.forEach(item => selectedIds.delete(item.id));
    updateBatchToolbarUI(); renderTablePage();
}
function updateBatchToolbarUI() { 
    const toolbar = document.getElementById("batch-toolbar"); const countText = document.getElementById("batch-count-text");
    if(selectedIds.size > 0) { toolbar.classList.remove("hidden"); countText.innerHTML = `เลือกแล้ว ${selectedIds.size} รายการ`; } 
    else { toolbar.classList.add("hidden"); } 
}

async function executeBatchAction(action) {
    if(selectedIds.size === 0) return;
    let actionName = action === 'delete' ? tDec('ลบ') : action === 'protect' ? tDec('ล็อก') : tDec('ปลดล็อก');
    if(!confirm(tDec(`คุณแน่ใจหรือไม่ว่าต้องการ ${actionName} ทั้ง ${selectedIds.size} รายการ?`))) return;
    
    const db = await initDB();
    const tx = db.transaction(["series", "chapters"], "readwrite"); const sStore = tx.objectStore("series"); const cStore = tx.objectStore("chapters");
    console.log(`[DB:BATCH] กำลังทำงาน ${actionName} จำนวน ${selectedIds.size} รายการ`);
    for(let id of selectedIds) { 
        const item = libData.find(d => d.id === id);
        if(!item) continue;
        const store = item._type === 'series' ? sStore : cStore; 
        if(action === 'delete') { if(!item.isLocked) store.delete(id);
        } else if(action === 'protect') { store.get(id).onsuccess = (e) => { let d = e.target.result; if(d) { d.isLocked = true; store.put(d); } }; 
        } else if(action === 'unprotect') { store.get(id).onsuccess = (e) => { let d = e.target.result; if(d) { d.isLocked = false; store.put(d); } }; } 
    }
    tx.oncomplete = () => { selectedIds.clear(); updateBatchToolbarUI(); initializeDashboard(); };
}

// --- CORE SYSTEM ACTIONS ---
async function toggleItemLock(type, id) { 
    const storeName = type === 'series' ? 'series' : 'chapters'; 
    const db = await initDB(); const tx = db.transaction(storeName, "readwrite"); const store = tx.objectStore(storeName);
    store.get(id).onsuccess = (e) => { let d = e.target.result; if(d) { d.isLocked = !d.isLocked; store.put(d); }};
    tx.oncomplete = () => { console.log(`[DB:LOCK] สลับสถานะสำหรับ ${id}`); initializeDashboard(); };
}

async function deleteItem(type, id, isLocked) { 
    if(isLocked) { alert(tDec("ข้อมูลถูกป้องกันไว้ กรุณาปลดล็อกก่อนลบ")); return; } 
    if(confirm(tDec("ต้องการลบข้อมูลนี้ถาวรหรือไม่?"))) { 
        const storeName = type === 'series' ? 'series' : 'chapters';
        const db = await initDB(); db.transaction(storeName, "readwrite").objectStore(storeName).delete(id).onsuccess = () => { console.log(`[DB:DELETE] ลบรายการ ${id} แล้ว`); initializeDashboard(); };
    } 
}

