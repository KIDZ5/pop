    selectedManga = { id: m.mal_id, title: title, authors: authorNames, artists: authorNames, romaji: m.title_japanese || "N/A", english: m.title_english || "N/A", native: m.title_japanese || "N/A", cover: imageUrl, desc: thaiSynopsis, status: m.status || "Unknown", type: m.type || "Manga", genres: m.genres ? m.genres.map(g => g.name) : [] };
    
