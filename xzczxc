// ฟังก์ชันวิเคราะห์หาเลขตอนจากแท็ก <a> ของเว็บ
function extractChapterInfo(aTag, baseUrl) {
    let href = aTag.href || aTag.getAttribute('href');
    let text = aTag.innerText.trim();
    if (!href || href.includes('javascript:') || href === '#' || href === '/') return null;
    
    // แปลงลิงก์สัมพัทธ์ให้เป็น URL เต็ม
    try { href = new URL(href, baseUrl).href; } catch(e){}

    // 1. หาเลขตอนจาก "ข้อความ" ก่อน เพราะมักจะชัดเจน (เช่น "ตอนที่ 164.10")
    let numMatch = text.match(/(?:ตอนที่|ตอน|Chapter|Ch\.|Ep\.)\s*(\d+(?:\.\d+)?)/i);
    
    // 2. ถ้าไม่เจอในข้อความ ให้เจาะจาก URL (บางเว็บใช้ขีดแทนจุด เช่น .../chapter-164-10/)
    if (!numMatch) {
        let urlPart = href.split('/').filter(Boolean).pop(); // เอาท่อนสุดท้ายของ URL
        numMatch = urlPart.match(/(\d+)[\.-](\d+)/); // จับทศนิยม (เช่น 164-10)
        if (numMatch) {
            numMatch = [null, `${numMatch[1]}.${numMatch[2]}`]; // แปลงให้เป็นจุด
        } else {
            numMatch = urlPart.match(/(\d+)/); // จับเลขธรรมดา
        }
    }

    if (numMatch && !href.includes('tag') && !href.includes('category')) {
        return { num: parseFloat(numMatch[1]), url: href };
    }
    return null;
}

