async function fetchHTML(targetUrl) {
    const proxies = [];
    if (GOOGLE_PROXY_URL && !GOOGLE_PROXY_URL.includes('ใส่_URL')) {
        proxies.push(`${GOOGLE_PROXY_URL}?url=${encodeURIComponent(targetUrl)}`);
