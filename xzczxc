        store.get(chapterId).onsuccess = (e) => { let d = e.target.result; if(d) { console.log(`[DB:RESOLVE] เชื่อมโยงตอน ${chapterId} เข้ากับ ${selectedSeries}`); d.commonTag = selectedSeries;
        d.isLocked = true; store.put(d); } };
        tx.oncomplete = () => { Swal.fire({title: tDec('สำเร็จ!'), html: tDec('เชื่อมโยงตอนและล็อกการเปลี่ยนแปลงเรียบร้อยแล้ว.'), icon: 'success', confirmButtonText: tDec('ตกลง')}); initializeDashboard(); };
    }
}

// AUTO RESOLVE ALL ORPHANS
async function resolveAllOrphans() {
    if(globalOrphanIds.length === 0) return;
    console.log("[DB:RESOLVE] เริ่มการแก้ไขตอนอัตโนมัติ...");
    const db = await initDB();
    const series = await new Promise(r => db.transaction("series").objectStore("series").getAll().onsuccess = e => r(e.target.result));
    const tx = db.transaction("chapters", "readwrite");
    const store = tx.objectStore("chapters");
    
    let resolvedCount = 0;
    for(let id of globalOrphanIds) {
        const chapter = await new Promise(r => store.get(id).onsuccess = e => r(e.target.result));
        if(!chapter) continue;
        
        let bestMatch = null;
        const cTag = (chapter.commonTag || "").toLowerCase().trim();
        const cTitle = (chapter.title || "").toLowerCase().trim();
        bestMatch = series.find(s => {
            const sTitle = s.title.toLowerCase();
            const sTag = (s.commonTag || "").toLowerCase();
            return (cTag.length > 3 && (sTitle.includes(cTag) || sTag.includes(cTag))) || (cTitle.includes(sTitle) || cTitle.includes(sTag));
        });
        if(bestMatch) {
            console.log(`[DB:RESOLVE] จับคู่อัตโนมัติ: ${chapter.title} --> ${bestMatch.title}`);
            chapter.commonTag = bestMatch.commonTag || bestMatch.title;
            chapter.isLocked = true;
            store.put(chapter);
            resolvedCount++;
        }
    }
    
    tx.oncomplete = () => {
        if(resolvedCount > 0) {
            Swal.fire({title: tDec('การแก้ไขอัตโนมัติสำเร็จ'), html: tDec(`จับคู่ตอนที่ไร้เรื่องหลักได้สำเร็จ ${resolvedCount} จาก ${globalOrphanIds.length} ตอน`), icon: 'success', confirmButtonText: tDec('ตกลง')});
        } else {
            Swal.fire({title: tDec('ไม่พบเรื่องที่จับคู่ได้'), html: tDec('ไม่สามารถหาเรื่องหลักที่ตรงกับตอนที่เหลือได้ กรุณาแก้ไขด้วยตนเองหรือลบข้อมูลทิ้ง'), icon: 'info', confirmButtonText: tDec('ตกลง')});
        }
        initializeDashboard();
    }
}

async function purgeAllOrphans() { 
    if(globalOrphanIds.length === 0 || !confirm(tDec(`ต้องการลบตอนที่ไร้เรื่องหลัก ${globalOrphanIds.length} ตอนอย่างถาวรหรือไม่?`))) return;
    console.log("[DB:PURGE] กำลังลบตอนที่ไม่มีเรื่องหลักทั้งหมด"); 
    const db = await initDB(); const tx = db.transaction("chapters", "readwrite"); const store = tx.objectStore("chapters");
    globalOrphanIds.forEach(id => store.delete(id));
    tx.oncomplete = () => { initializeDashboard(); }; 
}

